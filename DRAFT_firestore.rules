rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read: if true; // Public can read everything for a landing page
      allow write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // For this demo/applet, we allow the main user or any verified user to be "admin" 
      // if they are signed in. In production, we'd check an admins collection.
      return isEmailVerified();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Teams ---
    match /teams/{teamId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidTeam(incoming());
      allow delete: if isAdmin();

      function isValidTeam(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() < 100;
      }
    }

    // --- Players ---
    match /players/{playerId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPlayer(incoming());
      allow delete: if isAdmin();

      function isValidPlayer(data) {
        return data.name is string && data.name.size() > 0 && 
               data.teamId is string && exists(/databases/$(database)/documents/teams/$(data.teamId));
      }
    }

    // --- Matches ---
    match /matches/{matchId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidMatch(incoming());
      allow delete: if isAdmin();

      function isValidMatch(data) {
        return data.teamAId is string && data.teamBId is string &&
               data.date is string && data.status in ['scheduled', 'live', 'finished'];
      }
    }

    // --- Gallery ---
    match /gallery/{imageId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidGallery(incoming());
      allow delete: if isAdmin();

      function isValidGallery(data) {
        return data.url is string && data.url.size() > 0;
      }
    }
  }
}
